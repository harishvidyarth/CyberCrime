# =====================================================================
#  FundTrail environment template
#  1. Copy this file to ".env"      ->   cp .env.example .env
#  2. Fill in real values below
#  3. NEVER commit the real .env (it is in .gitignore)
# =====================================================================

# ----- Flask secret key (signs session cookies) ----------------------
# Generate a strong one:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-64-char-random-hex-string

# ----- Database ------------------------------------------------------
# If DATABASE_URL is NOT set, the app uses local SQLite (zero setup) —
# good for quick local development.
#
# To use MySQL (the target for this project), run setup.sql first, then
# uncomment and fill the line below:
# DATABASE_URL=mysql+pymysql://fundtrail:CHANGE_ME@localhost:3306/fundtrail

# Optional: override where SQLite database files are stored
# FUNDTRAIL_DATA_DIR=/absolute/path/to/data

# ----- Dev flags -----------------------------------------------------
# Enable Flask debugger ONLY on your own machine. NEVER true in prod
# (it exposes a remote code-execution console).
FLASK_DEBUG=false

# Allow login over local http (development only). Leave false in production —
# when true, session cookies are sent without HTTPS. See FT-010.
SESSION_COOKIE_INSECURE=false

# ----- Optional integrations ----------------------------------------
# Sentry error/performance telemetry. Leave blank to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ENABLE_LOGS=true
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILE_SESSION_SAMPLE_RATE=0.0
SENTRY_PROFILE_LIFECYCLE=trace

# Resend email delivery for password reset links. Leave RESEND_API_KEY blank to skip sending.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@fundtrail.app

# Disabled-by-default integration probes for staging/manual validation only.
ENABLE_INTEGRATION_TEST_ROUTES=false
INTEGRATION_TEST_TOKEN=
RESEND_TEST_TO=
