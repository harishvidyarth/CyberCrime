# FundTrail environment configuration.
# Copy this file to ".env" and fill in real values:  cp .env.example .env
# ".env" is gitignored and must NEVER be committed.  ".env.example" has no secrets.

# REQUIRED. Flask session signing key — the app refuses to start without it.
# Generate a fresh one:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-64-char-hex-secret

# Cookie security.
#   false (or unset) -> session cookies are marked Secure (HTTPS only). USE IN PRODUCTION.
#   true             -> Secure flag off; LOCAL HTTP DEV ONLY (http://127.0.0.1),
#                       otherwise login silently breaks over plain http.
SESSION_COOKIE_INSECURE=false

# Debug mode. MUST stay false outside local dev (debug exposes an interactive
# code console to anyone who can trigger an error).
FLASK_DEBUG=false

# Port to listen on. Default 5050 (5000 is often taken by macOS AirPlay Receiver).
PORT=5050

# OPTIONAL. Database URL. If unset, a local SQLite DB under ./data/ is used (dev).
# Production (MySQL) example:
#   DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/fundtrail
# DATABASE_URL=

# OPTIONAL. Override where SQLite DBs + INITIAL_CREDENTIALS.txt are stored.
# FUNDTRAIL_DATA_DIR=/secure/path/to/data

# OPTIONAL. Force a password change after N days (0 disables expiry). Default 90.
# Accounts with no recorded password age are not retroactively forced.
# PASSWORD_MAX_AGE_DAYS=90

# OPTIONAL. Log format: "json" emits one JSON object per line with a request_id
# on every entry (machine-parseable). Default is human-readable text.
# LOG_FORMAT=json
